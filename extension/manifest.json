{
  "manifest_version": 3,
  "name": "MediaVault Linker",
  "version": "1.0.0",
  "description": "Send video links to your MediaVault instance with one click.",
  "permissions": ["activeTab", "contextMenus", "storage", "notifications"],
  "host_permissions": ["*://*/api/downloads"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon.png"
  }
}
